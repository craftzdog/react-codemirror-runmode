{
  "name": "react-codemirror-runmode",
  "version": "2.2.1",
  "description": "Syntax highlighting for react, utilizing CodeMirror's parser",
  "keywords": [
    "codemirror",
    "highlight",
    "react",
    "syntax"
  ],
  "license": "MIT",
  "author": "Takuya Matsuyama <hi@craftz.dog>",
  "repository": {
    "type": "git",
    "url": "https://github.com/craftzdog/react-codemirror-runmode.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "test": "vitest",
    "lint": "oxlint",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "prepublishOnly": "npm-run-all lint format:check build && npm run test run"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3"
  },
  "devDependencies": {
    "@codemirror/theme-one-dark": "^6.1.3",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": ">= 18"
  }
}
